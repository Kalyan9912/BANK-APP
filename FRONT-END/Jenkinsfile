pipeline{
    agent any
    tools{
        nodejs "mynodejs"
    }
    stages{
        stage("Code Checkout"){
            steps{
                git branch: 'main', url: 'https://github.com/Kalyan9912/BANK-APP.git'
                
            }
        }
        stage("Build"){
            steps{
               sh 'cd FRONT-END && npm install'
               sh 'cd FRONT-END && npm run build'
            }
        }
        stage("TEST"){
            steps{
                sh 'cd FRONT-END && npm test -- --watchAll=false --passWithNoTests'
            }
        }
        stage("Docker Build"){
            steps{
               sh 'docker build -t kalyan:${BUILD_NUMBER} ./FRONT-END'
            }
        }
    }
}
